{
  "name": "agent-start",
  "version": "0.2.0",
  "private": true,
  "license": "MIT",
  "repository": "https://github.com/imanect-labs/agent-start",
  "description": "Root package: thin script proxy. Real front-end lives in ./front/ and is driven by Vite+ (vp CLI). Rust host lives in ./server-rs/.",
  "scripts": {
    "dev:front": "cd front && vp dev",
    "dev:host": "cd server-rs && cargo run --quiet -p agent-start-host -- --port 3030",
    "build": "cd front && vp build",
    "preview": "cd front && vp run preview",
    "typecheck": "cd front && vp check",
    "lint": "cd front && vp run oxlint",
    "fmt": "cd front && vp run oxfmt",
    "host": "cd server-rs && cargo run --quiet -p agent-start-host -- --port 3030",
    "host:build": "cd server-rs && cargo build --release"
  }
}
